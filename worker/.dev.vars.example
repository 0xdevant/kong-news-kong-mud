# Copy to .dev.vars for local wrangler dev (not committed)
# Optional: override `npm run refresh:prod` target (default: https://news.clawify.dev/api/refresh)
# REFRESH_URL=https://news.clawify.dev/api/refresh
# REFRESH_SECRET=your-secret
# PAGES_ORIGIN=https://news.clawify.dev
# FILTER_EXCLUDE_KEYWORDS=keyword1, keyword2
# FILTER_CLICKBAIT_PATTERNS=
# Optional contact form → Resend (messages always stored in D1)
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=you@example.com
# RESEND_FROM=港聞講乜 <onboarding@resend.dev>
# Optional: skip extra HTTP fetches for og:image when RSS has no photo (default: enabled)
# FETCH_OG_IMAGE=false
# FETCH_OG_IMAGE_MAX=25
